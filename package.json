{
  "name": "shipgate",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r --filter \"@shipgate/mortgage-app\" --filter \"@shipgate/api\" --filter \"@shipgate/analysis-ui\" dev",
    "dev:mortgage": "pnpm --filter @shipgate/mortgage-app dev",
    "dev:api": "pnpm --filter @shipgate/api dev",
    "dev:analysis-ui": "pnpm --filter @shipgate/analysis-ui dev",
    "dev:scheduler": "pnpm --filter @shipgate/scheduler-worker dev",
    "dev:web": "pnpm --filter @shipgate/web dev",
    "dev:worker": "pnpm --filter @shipgate/worker dev",
    "dev:all": "pnpm --parallel -r --filter \"@shipgate/mortgage-app\" --filter \"@shipgate/api\" --filter \"@shipgate/analysis-ui\" --filter \"@shipgate/scheduler-worker\" dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @shipgate/database generate",
    "db:migrate": "pnpm --filter @shipgate/database migrate",
    "db:push": "pnpm --filter @shipgate/database push",
    "db:seed": "pnpm db:generate && pnpm --filter @shipgate/database seed",
    "test:smoke": "cd tests/e2e && npx codeceptjs run --steps --grep @smoke",
    "test:regression": "cd tests/e2e && TEST_SUITE=regression npx codeceptjs run --steps",
    "jenkins:up": "bash infra/scripts/jenkins-up.sh",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  }
}
