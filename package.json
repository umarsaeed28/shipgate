{
  "name": "ai-qa-platform",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered managed-QA platform (MVP). One instance per client.",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:landing": "pnpm --filter @qa/landing run dev",
    "dev:app": "pnpm --filter @qa/app run dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "new-client": "tsx scripts/new-client.ts"
  },
  "dependencies": {
    "@qa/store": "workspace:*"
  },
  "devDependencies": {
    "@prisma/client": "^6.2.1",
    "@types/node": "^22.10.5",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.14.0"
}
