# Intelligence agent: Playwright (Chromium) + MCP-shaped tools + OpenAI loop → Shipgate Analysis API
FROM mcr.microsoft.com/playwright:v1.49.1-noble

WORKDIR /repo

RUN corepack enable && corepack prepare pnpm@9.14.2 --activate

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/agents/package.json packages/agents/
COPY packages/playwright-mcp-bridge/package.json packages/playwright-mcp-bridge/
COPY apps/playwright-agent/package.json apps/playwright-agent/

RUN pnpm install --frozen-lockfile

COPY packages/shared packages/shared
COPY packages/agents packages/agents
COPY packages/playwright-mcp-bridge packages/playwright-mcp-bridge
COPY apps/playwright-agent apps/playwright-agent

RUN pnpm --filter @shipgate/shared build \
  && pnpm --filter @shipgate/agents build \
  && pnpm --filter @shipgate/playwright-mcp-bridge build \
  && pnpm --filter @shipgate/playwright-agent build

ENV NODE_ENV=production
WORKDIR /repo/apps/playwright-agent

CMD ["node", "dist/index.js"]
