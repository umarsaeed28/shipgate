{
  "name": "@shipgate/e2e",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test:smoke": "MORTGAGE_APP_URL=http://localhost:3099 TEST_SUITE=smoke codeceptjs run --steps --grep @smoke",
    "test:regression": "MORTGAGE_APP_URL=http://localhost:3099 TEST_SUITE=regression codeceptjs run --steps",
    "test:all": "MORTGAGE_APP_URL=http://localhost:3099 codeceptjs run --steps",
    "test:headless": "HEADLESS=true MORTGAGE_APP_URL=http://localhost:3099 codeceptjs run --steps",
    "test:smoke:headless": "HEADLESS=true MORTGAGE_APP_URL=http://localhost:3099 TEST_SUITE=smoke codeceptjs run --steps --grep @smoke",
    "test:regression:headless": "HEADLESS=true MORTGAGE_APP_URL=http://localhost:3099 TEST_SUITE=regression codeceptjs run --steps",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "allure:clean": "rm -rf allure-results allure-report output"
  },
  "devDependencies": {
    "@codeceptjs/configure": "^0.10.0",
    "allure-codeceptjs": "^3.6.0",
    "allure-commandline": "^2.38.1",
    "codeceptjs": "^3.7.7",
    "playwright": "^1.59.1"
  }
}
