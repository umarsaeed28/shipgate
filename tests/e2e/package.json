{
  "name": "@shipgate/e2e",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "test": "npx codeceptjs run --steps",
    "test:smoke": "npx codeceptjs run --grep '@smoke' --steps",
    "test:report": "node report-to-shipgate.js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "devDependencies": {
    "allure-codeceptjs": "^3.6.0",
    "codeceptjs": "^3.7.7",
    "playwright": "^1.59.1"
  }
}
