CLIENT_SLUG=acme
DATABASE_URL=postgres://...
# When ANTHROPIC_API_KEY is unset or a local/placeholder value, @qa/llm uses a
# deterministic offline mock provider so the pipeline stays runnable locally.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ATLASSIAN_MCP_URL=https://mcp.atlassian.com/v1/mcp
APP_BASE_PATH=/app-acme
AUTH_SECRET=...

# Worker (optional)
# WORKER_POLL_MS=1000        # queue poll interval
# QA_SCHEDULE_MS=0           # >0 enables periodic CodeceptJS suite runs
