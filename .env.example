CLIENT_SLUG=acme
DATABASE_URL=postgres://...

# Model provider. The deployed path runs Claude through Amazon Bedrock using the
# AWS credential chain (an IAM role); no model provider API key is used. Region,
# model id, the optional VPC endpoint, and the KMS key are all read from env.
# See docs/bedrock.md.
LLM_PROVIDER=bedrock
AWS_REGION=
BEDROCK_MODEL_ID=
BEDROCK_VPC_ENDPOINT=
KMS_KEY_ID=
# Local development may instead use LLM_PROVIDER=anthropic with ANTHROPIC_API_KEY.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

ATLASSIAN_MCP_URL=https://mcp.atlassian.com/v1/mcp
APP_BASE_PATH=/app-acme
AUTH_SECRET=...

# Read-only public demo. When set, all mutations are blocked server-side so the
# workspace is safe to expose; role switching stays on. See docs/demo.md.
# DEMO_MODE=1
# Landing "Open a demo workspace" link (inlined at build time for the landing app).
# NEXT_PUBLIC_APP_DEMO_URL=http://localhost:3100/app-acme

# Worker (optional)
# WORKER_POLL_MS=1000        # queue poll interval
# QA_SCHEDULE_MS=0           # >0 enables periodic CodeceptJS suite runs
